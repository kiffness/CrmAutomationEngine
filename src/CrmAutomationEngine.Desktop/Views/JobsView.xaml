<UserControl x:Class="CrmAutomationEngine.Desktop.Views.JobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <Button Content="Load" Command="{Binding LoadCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Type"      Binding="{Binding JobType}"    Width="100"/>
                <DataGridTextColumn Header="Status"    Binding="{Binding Status}"     Width="100"/>
                <DataGridTextColumn Header="Created"   Binding="{Binding CreatedAt, StringFormat='{}{0:g}'}"   Width="140"/>
                <DataGridTextColumn Header="Completed" Binding="{Binding CompletedAt, StringFormat='{}{0:g}'}" Width="140"/>
                <DataGridTextColumn Header="Error"     Binding="{Binding ErrorMessage}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button Content="&#8592; Prev" Command="{Binding PrevPageCommand}" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding PageDisplay}" VerticalAlignment="Center"/>
            <Button Content="Next &#8594;" Command="{Binding NextPageCommand}" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
