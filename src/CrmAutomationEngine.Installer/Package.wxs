<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="CRM Automation Engine"
           Manufacturer="CrmAutomationEngine"
           Version="1.0.0"
           UpgradeCode="b1e2f3a4-c5d6-7e8f-9a0b-c1d2e3f4a5b6"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of CRM Automation Engine is already installed."/>
    <MediaTemplate EmbedCab="yes"/>

    <!-- Holds the server URL entered by the user during setup -->
    <Property Id="SERVER_URL" Value="https://"/>
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER"/>

    <!-- Directories -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="CRM Automation Engine"/>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="CRM Automation Engine"/>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder"/>

    <!--
      Shortcuts component.
      Needs a RegistryValue KeyPath because shortcuts are not valid KeyPaths.
    -->
    <Component Id="AppShortcuts" Directory="AppMenuFolder" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="CRM Automation Engine"
                Description="Manage your CRM automations"
                Target="[INSTALLFOLDER]CrmAutomationEngine.Desktop.exe"
                WorkingDirectory="INSTALLFOLDER"/>
      <Shortcut Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="CRM Automation Engine"
                Description="Manage your CRM automations"
                Target="[INSTALLFOLDER]CrmAutomationEngine.Desktop.exe"
                WorkingDirectory="INSTALLFOLDER"/>
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall"/>
      <RegistryValue Root="HKCU"
                     Key="Software\CrmAutomationEngine"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes"/>
    </Component>

    <!-- Feature: installs harvested Desktop binaries + shortcuts -->
    <Feature Id="Main" Title="CRM Automation Engine" Level="1">
      <ComponentGroupRef Id="CrmAutomationEngine.Desktop.Binaries"/>
      <ComponentRef Id="AppShortcuts"/>
    </Feature>

    <!--
      After files are installed, write the user-supplied SERVER_URL into appsettings.json.
      ElementPath uses JSONPath syntax.
    -->
    <util:JsonFile Id="WriteServerUrl"
                   File="[INSTALLFOLDER]appsettings.json"
                   Action="setValue"
                   ElementPath="$.ServerUrl"
                   Value="[SERVER_URL]"/>

    <UIRef Id="CrmSetupUI"/>

  </Package>
</Wix>
